# Google Drive integration
# Copy this file to .env and fill in your values. Never commit .env to git.
#
# How to get these:
#   1. Go to console.cloud.google.com
#   2. Create a project and enable the Google Drive API
#   3. Credentials → Create → OAuth 2.0 Client ID → Application type: Desktop app
#   4. Copy the Client ID and Client Secret below
#
# These are embedded in the compiled binary (normal for Desktop OAuth clients).
# Even if extracted, they can only be used to show a consent screen — no data
# can be accessed without the user clicking Allow.
GDRIVE_CLIENT_ID=
GDRIVE_CLIENT_SECRET=
