{
  "name": "warroom",
  "version": "0.1.0",
  "description": "Tactical prep tool for competitive policy debaters",
  "main": "out/main/index.cjs",
  "type": "module",
  "author": "Warroom",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
