    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "ws": "^8.20.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
